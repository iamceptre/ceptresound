---
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';

const navLinks = [
    { href: '/showreel', label: 'Showreel' },
    { href: '/',         label: 'Home'     },
    { href: '/about',    label: 'About'    },
    { href: '/projects', label: 'Projects' },
];

import CopyToClipboard from './CopyToClipboard'
---

<header>
    <div class="logo">
        <a href="/">
            <img src="/ceptre-logo.png" alt="ceptre logo" width="32" height="32" loading="eager" decoding="async" data-manual-fade />
        </a>
        <div>
            <span><a href="https://linktr.ee/ceptre" target="_blank" rel="noopener noreferrer">Łukasz Brandeburg</a></span>
            <span>Sound Designer | Music Producer | Composer</span>
        </div>
    </div>

    <input type="checkbox" id="menu-toggle" />
    <label for="menu-toggle" class="menu-button-wrapper" aria-label="Toggle navigation">
        <div class="menu-button"></div>
    </label>

    <nav>
        {navLinks.map(link => (
            <a
                href={link.href}
                class={currentPath === link.href ? 'active' : undefined}
                aria-current={currentPath === link.href ? 'page' : undefined}
            >
                {link.label}
            </a>
        ))}
    </nav>

    <div class="email-wrapper">
        <CopyToClipboard client:visible />
    </div>
</header>
<hr>

<style>
    header {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        align-items: center;
    }

    nav {
        display: flex;
        justify-content: center;
        gap: var(--size-500);
        align-items: center;
    }

    a {
        text-decoration: none;
        color: black;
    }

    .active {
        font-weight: 700;
    }

    .menu-button-wrapper {
        display: none;
        justify-content: flex-end;
        z-index: 60;
        cursor: pointer;
    }

    .menu-button {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 1.5rem;
        height: 1rem;
    }

    .menu-button::before,
    .menu-button::after {
        content: '';
        display: block;
        background-color: black;
        position: absolute;
        height: 2px;
        width: 1.25rem;
        transition: transform 0.15s;
    }

    .menu-button::before { margin-top: -8px; }
    .menu-button::after  { margin-top:  8px; }

    #menu-toggle:checked + .menu-button-wrapper .menu-button::before {
        margin-top: 0;
        transform: rotate(45deg);
    }
    #menu-toggle:checked + .menu-button-wrapper .menu-button::after {
        margin-top: 0;
        transform: rotate(-45deg);
    }

    .email-wrapper { text-align: end; }

    .logo {
        display: flex;
        align-items: center;
        gap: var(--size-500);
    }

    .logo img {
        max-width: 2rem;
        height: 2rem;
    }

    .logo > div {
        display: flex;
        flex-direction: column;
    }

    .logo > div > span:nth-child(2) {
        color: var(--cl-grey-800);
        font-size: var(--size-300);
    }

    #menu-toggle { display: none; }

    @media screen and (max-width: 30rem) {
        .logo > div > span:nth-child(2) { display: none; }
    }

    @media screen and (max-width: 60rem) {
        header {
            grid-template-columns: 1fr min-content;
            gap: 1rem;
        }

        nav {
            flex-direction: column;
            position: fixed;
            top: 0;
            right: -100%;
            width: 100%;
            height: 100%;
            background-color: var(--cl-bg);
            transition: right 0.15s ease;
            view-transition-name: none;
            z-index: 50;
        }

        .menu-button-wrapper { display: block; }

        #menu-toggle:checked ~ nav { right: 0; }

        .email-wrapper { display: none; }
    }
</style>

<script>
    let spaceHandler: ((e: KeyboardEvent) => void) | null = null;

    const isMobile = () => window.matchMedia('(hover: none) and (pointer: coarse)').matches;
    const isWebKit = () => navigator.vendor === 'Apple Computer, Inc.';

    function setupMenu() {
        const checkbox = document.getElementById('menu-toggle') as HTMLInputElement | null;
        if (checkbox) checkbox.checked = false;
        document.documentElement.style.overflow = '';

        checkbox?.addEventListener('change', () => {
            const open = checkbox.checked;
            document.documentElement.style.overflow = open ? 'hidden' : '';

            for (const v of document.getElementsByTagName('video')) {
                v.classList.toggle('zindex-video', open);
                const wrap = v.parentElement;
                if (wrap instanceof HTMLElement && getComputedStyle(wrap).position === 'relative') {
                    wrap.style.zIndex = open ? '-1' : '';
                }
            }

            if (!open) window.scrollTo({ top: 0, behavior: 'smooth' });
        });
    }

    function updateActiveLink() {
        const current = window.location.pathname.replace(/\/$/, '') || '/';
        for (const link of document.querySelectorAll<HTMLAnchorElement>('nav a[href]')) {
            const href = (link.getAttribute('href') ?? '').replace(/\/$/, '') || '/';
            const active = current === href;
            link.classList.toggle('active', active);
            if (active) link.setAttribute('aria-current', 'page');
            else link.removeAttribute('aria-current');
        }
    }

    function setupSpacebar() {
        if (isMobile()) return;

        if (spaceHandler) document.removeEventListener('keydown', spaceHandler);

        spaceHandler = (e: KeyboardEvent) => {
            if (e.code !== 'Space') return;
            const tag = (document.activeElement as Element)?.tagName;
            if (tag === 'INPUT' || tag === 'TEXTAREA' || tag === 'BUTTON') return;
            const video = document.querySelector<HTMLVideoElement>('video');
            if (!video) return;
            e.preventDefault();
            if (video.paused) {
                const wrap = video.parentElement;
                if (wrap instanceof HTMLElement && getComputedStyle(wrap).position === 'relative') {
                    const flash = document.createElement('div');
                    flash.setAttribute('aria-hidden', 'true');
                    flash.style.cssText =
                        'position:absolute;inset:0;background:white;pointer-events:none;' +
                        'animation:video-flash 200ms ease forwards;';
                    wrap.appendChild(flash);
                    flash.addEventListener('animationend', () => flash.remove(), { once: true });
                }
                video.play();
            } else {
                video.pause();
            }
        };

        document.addEventListener('keydown', spaceHandler);
    }

    function setupVideoThumbnails() {
        if (isMobile() || isWebKit()) return;

        for (const video of document.querySelectorAll<HTMLVideoElement>('video[poster="/black-16-9.png"]')) {

            video.style.visibility = 'hidden';

            const build = () => {
                try {
                    const canvas = document.createElement('canvas');
                    canvas.width  = video.videoWidth  || 1280;
                    canvas.height = video.videoHeight || 720;
                    canvas.getContext('2d')!.drawImage(video, 0, 0);
                    video.currentTime = 0;

                    const wrap = document.createElement('div');
                    wrap.className = video.className;
                    wrap.style.cssText = 'position:relative;line-height:0;';
                    video.removeAttribute('class');
                    video.style.cssText = 'width:100%;height:auto;display:block;visibility:hidden;';
                    video.parentElement!.insertBefore(wrap, video);
                    wrap.appendChild(video);

                    const thumb = document.createElement('img')
                    thumb.src = canvas.toDataURL('image/jpeg', 0.8)
                    thumb.alt = ''
                    thumb.setAttribute('aria-hidden', 'true');
                    thumb.style.cssText =
                        'position:absolute;inset:0;width:100%;height:100%;object-fit:cover;pointer-events:none;';

                    const playBtn = document.createElement('div');
                    playBtn.setAttribute('aria-hidden', 'true');
                    playBtn.style.cssText =
                        'position:absolute;inset:0;display:flex;align-items:center;justify-content:center;pointer-events:none;';
                    playBtn.innerHTML =
                        '<svg viewBox="0 0 64 64" width="64" height="64" xmlns="http://www.w3.org/2000/svg"' +
                        ' style="filter:drop-shadow(0 2px 8px rgba(0,0,0,.5))">' +
                        '<circle cx="32" cy="32" r="32" fill="rgba(0,0,0,.45)"/>' +
                        '<polygon points="20.6,14.9 20.6,49.1 50.3,32.0" fill="white"/>' +
                        '</svg>';

                    const overlay = document.createElement('div');
                    overlay.style.cssText = 'position:absolute;inset:0;cursor:pointer;';

                    wrap.appendChild(thumb)
                    requestAnimationFrame(() => thumb.classList.add('visible'))
                    wrap.appendChild(playBtn);
                    wrap.appendChild(overlay);

                    video.addEventListener('play', () => {
                        thumb.remove();
                        playBtn.remove();
                        overlay.remove();
                        video.style.visibility = 'visible';
                    }, { once: true });

                    overlay.addEventListener('click', (e) => {
                        e.stopPropagation();

                        const flash = document.createElement('div');
                        flash.setAttribute('aria-hidden', 'true');
                        flash.style.cssText =
                            'position:absolute;inset:0;background:white;pointer-events:none;' +
                            'animation:video-flash 200ms ease forwards;';
                        wrap.appendChild(flash);
                        flash.addEventListener('animationend', () => flash.remove(), { once: true });

                        video.play();
                    }, { once: true });

                } catch {
                    video.style.visibility = 'visible';
                }
            };

            const showFallback = () => { video.style.visibility = 'visible'; };

            const seekAndBuild = () => {
                video.currentTime = Math.min(video.duration * 0.1, 1);
                const seekTimeout = setTimeout(showFallback, 3000);
                video.addEventListener('seeked', () => {
                    clearTimeout(seekTimeout);
                    build();
                }, { once: true });
            };

            video.addEventListener('error', showFallback, { once: true });

            if (video.readyState >= 1) {
                seekAndBuild();
            } else {
                if (video.preload === 'none') video.preload = 'metadata';
                const metaTimeout = setTimeout(showFallback, 5000);
                video.addEventListener('loadedmetadata', () => {
                    clearTimeout(metaTimeout);
                    seekAndBuild();
                }, { once: true });
            }
        }
    }

    document.addEventListener('astro:before-preparation', () => {
        document.documentElement.classList.add('is-transitioning');
    });

    document.addEventListener('astro:page-load', () => {
        document.documentElement.classList.remove('is-transitioning');
        setupMenu();
        updateActiveLink();
        setupSpacebar();
        setupVideoThumbnails();
    });
</script>