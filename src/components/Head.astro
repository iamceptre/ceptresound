---
import '../styles/global.css'
import { ViewTransitions } from 'astro:transitions'

export interface Props {
    title: string
    description?: string
    image?: string
}

const { title, description, image } = Astro.props
const ogImage = image ? new URL(image, Astro.site).toString() : undefined
---

<head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="title" content={title} />
    {description && <meta name="description" content={description} />}

    <meta property="og:type"  content="website" />
    <meta property="og:url"   content={Astro.url} />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta name="twitter:card"  content={ogImage ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    {ogImage && <meta name="twitter:image" content={ogImage} />}

    <link rel="preload" href="/fonts/InterVariable.woff2" as="font" type="font/woff2" crossorigin />

    <ViewTransitions />

    <script>
        function initImages() {
            document.querySelectorAll<HTMLImageElement>('img:not([data-manual-fade])').forEach(img => {
                if (img.classList.contains('visible')) return
                if (img.complete && img.naturalWidth > 0) {
                    img.classList.add('visible')
                } else if (img.getAttribute('src')) {
                    img.addEventListener('load',  () => img.classList.add('visible'), { once: true })
                    img.addEventListener('error', () => img.classList.add('visible'), { once: true })
                }
            })
        }

        initImages()
        window.addEventListener('pageshow', (e) => { if (e.persisted) initImages() })
        document.addEventListener('astro:page-load', initImages)

        function openExternalLinks() {
            document.querySelectorAll<HTMLAnchorElement>('a[href]').forEach(link => {
                if (link.hostname && link.hostname !== location.hostname) {
                    link.target = '_blank'
                    link.rel    = 'noopener noreferrer'
                }
            })
        }
        openExternalLinks()
        document.addEventListener('astro:page-load', openExternalLinks)
    </script>
</head>