---
import Head from '../components/Head.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../config';
import { Image } from 'astro:assets';

export interface Props {
    content: {
        title: string;
        description?: string;
        thumbnail?: string;
        heroImage?: string;
        heroImageWidth?: number;
        heroImageHeight?: number;
        video?: string;
        videoWidth?: number;
        videoHeight?: number;
        footerVideo?: string;
    };
}

const { content: { title, description, thumbnail, heroImage, heroImageWidth, heroImageHeight, video, videoWidth, videoHeight, footerVideo } } = Astro.props;
---

<html lang="en">
    <Head title={`${title} / ${SITE_TITLE}`} description={description} image={thumbnail} />
    <body>
        <section class="main-wrapper">
            <Header />
            <main>
                <div class="media-wrapper">
                    {heroImage && (
                        <Image
                            class="hero-image"
                            src={heroImage}
                            width={heroImageWidth ?? 1280}
                            height={heroImageHeight ?? 720}
                            quality={90}
                            loading="eager"
                            fetchpriority="high"
                            alt=""
                        />
                    )}
                    {video && (
                        <video
                            controls
                            preload="auto"
                            class="video"
                            poster="/black-16-9.png"
                            playsinline
                            width={videoWidth ?? 1280}
                            height={videoHeight ?? 720}
                        >
                            <source src={video} type="video/mp4" />
                            Your browser does not support the video tag.
                        </video>
                    )}
                </div>
                <div class="title">{title}</div>
                <hr />
                <slot />
                {footerVideo && (
                    <video
                        controls
                        preload="metadata"
                        class="footer-video"
                        poster="/black-16-9.png"
                        playsinline
                        width={videoWidth ?? 1280}
                        height={videoHeight ?? 720}
                    >
                        <source src={footerVideo} type="video/mp4" />
                        Your browser does not support the video tag.
                    </video>
                )}
            </main>
            <Footer />
        </section>
    </body>
</html>

<style>
    main {
        max-width: 38.2rem;
        margin-inline: auto;
    }

    .title {
        font-size: var(--size-700);
        margin-top: 1rem;
        text-align: center;
    }

    .media-wrapper {
        display: flex;
        justify-content: center;
    }

    .hero-image {
        width: 100%;
        height: auto;
        display: block;
    }

    .video,
    .footer-video {
        width: 100%;
        height: auto;
    }

    .footer-video {
        margin-top: 1rem;
    }

    :global(p)       { margin-bottom: 1rem; }
    :global(h2),
    :global(h3)      { margin-top: 1.5rem; margin-bottom: 0.5rem; font-weight: bold; color: var(--cl-grey-800); }
    :global(ul),
    :global(ol)      { padding-left: 1.5rem; margin-bottom: 1rem; }
    :global(li)      { margin-bottom: 0.5rem; }
    :global(a)       { text-decoration-style: solid; color: black; }
    :global(i)       { font-style: italic; color: var(--cl-grey-800); margin-bottom: 0.5rem; }
    :global(b)       { font-weight: 600; }
</style>
