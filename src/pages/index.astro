---
import Head from '../components/Head.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import { SITE_TITLE } from '../config'
---

<html lang="en">
    <Head title={SITE_TITLE} />
    <body>
        <section class="main-wrapper">
            <Header />
            <main>
                <div>
                    <div>
                        I'm a Sound Designer and Music Producer with experience dating back to 2014.
                        <br><br><p> I implement using <i>Wwise, MetaSound and FMOD</i>. <br><br></p>
                        My background in game visuals and code helps me speak the team's language, which makes the whole collaboration a lot smoother.
                    </div>
                      <section class="info-wrapper">
                        <div>
                            <div class="category">Sound / Music</div>
                            <span>Ableton, Reaper, Nuendo, RX Pro</span>
                        </div>
                        <div>
                            <div class="category">Graphics Design</div>
                            <span>Photoshop, After Effects, Blender</span>
                        </div>
                        <div>
                            <div class="category">Game Development</div>
                            <span title="Unreal Engine 3, 4 & 5">Unity, Unreal Engine, Fmod, Wwise</span>
                        </div>
                    </section>
                </div>
                <div class="hero-wrapper">
                    <img
                        id="hero-low"
                        src="/hero-low.webp"
                        width="720"
                        alt="hero image"
                        fetchpriority="high"
                        data-manual-fade
                    />
                    <img
                        id="hero-full"
                        src=""
                        width="720"
                        alt=""
                        aria-hidden="true"
                        data-manual-fade
                    />
                </div>
            </main>
            <Footer />
        </section>
    </body>
</html>

<script>
    function initHero() {
        const low  = document.getElementById('hero-low')  as HTMLImageElement
        const full = document.getElementById('hero-full') as HTMLImageElement
        if (!low || !full) return

        low.classList.remove('visible')
        full.classList.remove('visible')

        if (low.complete && low.naturalWidth > 0) {
            low.classList.add('visible')
        } else {
            low.addEventListener('load', () => low.classList.add('visible'), { once: true })
        }

        const hi = new Image()
        hi.onload = () => {
            full.src = hi.src
            requestAnimationFrame(() => full.classList.add('visible'))
        }
        hi.src = '/hero.jpg'
    }

    initHero()
    window.addEventListener('pageshow', (e) => { if (e.persisted) initHero() })
    document.addEventListener('astro:page-load', initHero)
</script>

<style>
    .hero-wrapper {
        position: relative;
    }

    #hero-full {
        position: absolute;
        inset: 0;
    }

    main {
        display: grid;
        grid-template-columns: auto auto;
        align-items: center;
        gap: var(--size-900);
        max-width: 45rem;
        margin-inline: auto;
    }

    main > div {
        display: grid;
        gap: var(--size-900);
    }

    .info-wrapper {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .category {
        color: var(--cl-grey-800);
    }

    @media screen and (max-width: 60rem) {
        main {
            display: flex;
            flex-direction: column;
            justify-content: center;
            gap: var(--size-700);
            max-width: 20rem;
        }

        main > div {
            gap: var(--size-700);
        }

        img {
            width: 320px;
        }
    }
</style>