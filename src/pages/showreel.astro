---
import Head from '../components/Head.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import { SITE_TITLE } from '../config'
---

<html lang="en">
    <Head title={SITE_TITLE} description="Showreel 2025 — Łukasz Brandeburg" />
    <body>
        <section class="main-wrapper">
            <Header />
            <main>
                <video id="showreel-video" controls preload="auto" class="responsive-video" poster="/black-16-9.png" playsinline width="1280" height="720">
                    <source src="/showreel-current.mp4" type="video/mp4" />
                    Your browser does not support the video tag.
                </video>
            </main>
            <Footer />
        </section>
    </body>
</html>

<style>
    main {
        display: grid;
        place-content: center;
    }

    .responsive-video {
        width: 62vw;
        max-width: 100%;
        height: auto;
    }
</style>
