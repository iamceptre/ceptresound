---
import Head from '../components/Head.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import { SITE_TITLE } from '../config'

const allProjects = (await Astro.glob('./projects/*.md'))

const groupProjectsByTag = (projects: any[]) => {
    const grouped: Record<string, any[]> = {}
    projects.forEach((project) => {
        const tag = project.frontmatter.tag
        if (!grouped[tag]) grouped[tag] = []
        grouped[tag].push(project)
    })
    return grouped
}

const categoryOrder = ['Game Development', 'Sound Design', 'Music', 'Visual Design']

const groupedProjects = groupProjectsByTag(allProjects)

Object.values(groupedProjects).forEach((projects) => {
    projects.sort((a, b) =>
        new Date(b.frontmatter.createdAt).valueOf() - new Date(a.frontmatter.createdAt).valueOf()
    )
})

const formatLabel = (tag: string) =>
    tag.replace(/-+/g, ' ').replace(/\b\w/g, c => c.toUpperCase())

const sections = Object.entries(groupedProjects)
    .map(([tag, projects]: [string, any[]]) => ({
        id: tag.toLowerCase().replace(/\s+/g, '-'),
        label: formatLabel(tag),
        projects,
    }))
    .sort((a, b) => categoryOrder.indexOf(a.label) - categoryOrder.indexOf(b.label))
---

<html lang="en">
    <Head title={`Projects / ${SITE_TITLE}`} />
    <body>
        <section class="main-wrapper">
            <Header />
            <main>
                <div class="category-nav">
                    {sections.map(({ id, label }, i) => (
                        <>
                            <a href={`#${id}`}>{label}</a>
                            {i < sections.length - 1 && <span class="pipe">|</span>}
                        </>
                    ))}
                </div>
                <hr>
                {sections.map(({ id, label, projects }) => (
                    <section id={id}>
                        <div class="category-label">{label}</div>
                        <div class="projects">
                            {projects.map((project: any) => (
                                <div class="project">
                                    <a href={project.url}>
                                        <img
                                            src={project.frontmatter.thumbnail}
                                            alt={project.frontmatter.title}
                                            loading="lazy"
                                            decoding="async"
                                        />
                                        <div class="info-wrapper">
                                            <div>{project.frontmatter.title}</div>
                                            <div class="meta">
                                                <div>{project.frontmatter.date}</div>
                                                <div>({project.frontmatter.category})</div>
                                            </div>
                                        </div>
                                    </a>
                                </div>
                            ))}
                        </div>
                    </section>
                ))}
            </main>
            <Footer />
        </section>
    </body>
</html>

<style>
    html {
        scroll-behavior: smooth;
    }

    main {
        max-width: 60rem;
        margin-inline: auto;
    }

    a {
        text-decoration: none;
        color: black;
    }

    .category-nav {
        display: flex;
        justify-content: center;
        gap: 0.5rem;
    }

    .projects {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: var(--size-700);
    }

    .category-label {
        color: var(--cl-grey-800);
        margin-block: 3rem;
    }

    .project {
        display: flex;
        flex-direction: column;
        background-color: var(--cl-bg-secondary);
    }

    .project img {
        aspect-ratio: 5 / 3;
        object-fit: cover;
        width: 100%;
    }

    .project img:hover {
        cursor: pointer;
    }

    .project > a {
        height: 100%;
        display: flex;
        flex-direction: column;
    }

    .info-wrapper {
        height: 100%;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        padding: 1rem;
        gap: var(--size-700);
    }

    .meta {
        display: flex;
        justify-content: space-between;
        font-size: var(--size-400);
        color: var(--cl-grey-800);
    }

    @media screen and (max-width: 60rem) {
        .projects {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @media screen and (max-width: 35rem) {
        .projects {
            grid-template-columns: 1fr;
        }

        .pipe {
            display: none;
        }

        .category-nav {
            flex-direction: column;
            align-items: center;
        }
    }
</style>
